# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Azure SQL / mssql-django)
DB_ENGINE=mssql
DB_NAME=HellenvanMeene
DB_USER=<sql-user>
DB_PASSWORD=<sql-password>
DB_HOST=<server>.database.windows.net
DB_PORT=1433

# Azure Blob Storage (django-storages)
AZURE_ACCOUNT_NAME=<storage-account-name>
AZURE_ACCOUNT_KEY=<storage-account-key>
AZURE_CONTAINER=<blob-container-name>

# SendGrid / Anymail
SENDGRID_API_KEY=SG.<your-key>
DEFAULT_FROM_EMAIL=noreply@hellenvanmeene.com

# Production only
# DJANGO_SETTINGS_MODULE=config.settings.prod
