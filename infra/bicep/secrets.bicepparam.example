// Copy this file to secrets.bicepparam and fill in values.
// secrets.bicepparam is listed in .gitignore — NEVER commit it.
using './main.bicep'

param secretKey = 'your-django-secret-key'
param dbPassword = 'your-azure-sql-password'
param sendgridApiKey = 'your-sendgrid-api-key'
param azureAccountKey = 'your-blob-storage-account-key'

// Non-sensitive but environment-specific:
param dbHost = 'your-server.database.windows.net'
param dbUser = 'your-sql-username'
param azureAccountName = 'your-storage-account'
